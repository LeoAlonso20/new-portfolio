---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectsSection from "@/components/ProjectsSection.astro";
import HeroSection from "@/components/react/HeroSection";
import SkillsSection from "@/components/react/SkillsSection";
import AboutSection from "@/components/react/AboutSection";
import ContactSection from "@/components/react/ContactSection";
import { useTranslations } from "@/i18n";
import type { Locale } from "@/i18n";

const locale: Locale = "es";
const t = useTranslations(locale);

const desiredOrder = [
  "es-meta-project",
  "es-validador-experto",
  "es-info-app",
  "es-lineo-app",
  "es-home-info",
  "es-lineo-home",
];

const hiddenSlugs = [
  "es-taskflow",
  "es-pulse-analytics",
  "taskflow",
  "pulse-analytics",
];

const projects = (await getCollection("projects"))
  .filter(
    (p) =>
      p.data.locale === locale &&
      p.data.featured &&
      !hiddenSlugs.includes(p.id)
  )
  .sort((a, b) => {
    const aIdx = desiredOrder.indexOf(a.id);
    const bIdx = desiredOrder.indexOf(b.id);
    if (aIdx === -1 && bIdx === -1) return 0;
    if (aIdx === -1) return 1;
    if (bIdx === -1) return -1;
    return aIdx - bIdx;
  });
---

<BaseLayout locale={locale}>
  <HeroSection
    client:load
    greeting={t.hero.greeting}
    name={t.hero.name}
    role={t.hero.role}
    description={t.hero.description}
    company={t.hero.company}
    ctaLabel={t.hero.cta}
    contactLabel={t.hero.contact}
    ctaHref="#projects"
    contactHref="#contact"
  />

  <ProjectsSection projects={projects} locale={locale} />

  <SkillsSection
    client:visible
    title={t.skills.title}
    subtitle={t.skills.subtitle}
  />

  <AboutSection
    client:visible
    title={t.about.title}
    paragraphs={[t.about.p1, t.about.p2, t.about.p3]}
  />

  <ContactSection
    client:visible
    title={t.contact.title}
    subtitle={t.contact.subtitle}
    emailLabel={t.contact.emailLabel}
    linkedinLabel={t.contact.linkedinLabel}
    githubLabel={t.contact.githubLabel}
    emailCta={t.contact.email}
  />
</BaseLayout>
